# MongoDB Configuration
# =====================

# Connection Options:
# 1. Local MongoDB: mongodb://localhost:27017
# 2. MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/database
# 3. Docker Container: mongodb://mongodb:27017

# Development - Local MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=sentinel_net
# MONGODB_USERNAME=admin
# MONGODB_PASSWORD=password123

# Production - MongoDB Atlas
# MONGODB_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DATABASE=sentinel_net_prod

# Optional: Replica Set (for transactions)
# MONGODB_REPLICA_SET=rs0

# Connection Pool Settings
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=30000

# Database Features
MONGODB_ENABLE_TRANSACTIONS=false

# FastAPI Settings
FASTAPI_ENV=development
FASTAPI_DEBUG=true
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0

# GitHub API
GITHUB_TOKEN=your_github_token_here

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
