# Sentinel-Net Environment Configuration

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
ENVIRONMENT=development

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_AUTO_REFRESH=true
VITE_REFRESH_INTERVAL=30000

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (full), read:org, gist

# Database Configuration (Optional - for production)
# DATABASE_URL=postgresql://user:password@localhost/sentinel_net
# REDIS_URL=redis://localhost:6379/0

# ML Model Configuration
ML_MODEL_CONFIDENCE_THRESHOLD=0.65
ML_ANOMALY_CONTAMINATION=0.1
ML_FEATURE_IMPORTANCE_TOP_N=5

# NLP Configuration
NLP_MAX_BATCH_SIZE=32
NLP_KEYWORD_EXTRACTION_TOP_N=5

# Security (for production)
# CORS_ORIGINS=https://yourdomain.com
# API_KEY_SECRET=your_secret_key_here
# JWT_SECRET=your_jwt_secret_here

# Monitoring & Logging
LOG_TO_FILE=false
# LOG_FILE_PATH=./logs/sentinel-net.log

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_RECONNECT_ATTEMPTS=5
WS_RECONNECT_DELAY=3000

# Data Retention
SIGNAL_HISTORY_LIMIT=1000
ANALYSIS_HISTORY_LIMIT=100
TEMPORAL_DATA_WINDOW_HOURS=24

# Feature Flags
ENABLE_REAL_TIME_ANALYSIS=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_ML_PREDICTIONS=true
ENABLE_WEBSOCKET=true

# Development Only
DEBUG=false
MOCK_DATA_MODE=false  # Set to true to use mock data instead of real GitHub analysis
